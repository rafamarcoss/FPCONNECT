# 🔐 Configuración del Backend - FPConnect

# ========== SERVIDOR ==========
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# ========== BASE DE DATOS ==========
# PostgreSQL local (desarrollo)
DATABASE_URL="postgresql://fpconnect_user:fpconnect_pass@localhost:5432/fpconnect_db?schema=public"

# ========== AUTENTICACIÓN JWT ==========
JWT_SECRET=tu_super_secret_jwt_key_very_long_and_random_string_here_2024
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=tu_super_secret_refresh_key_muy_largo_y_aleatorio_2024
REFRESH_TOKEN_EXPIRES_IN=30d

# ========== CORS ==========
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:3001,http://192.168.1.100:5173

# ========== EMAIL (Opcional para futuro) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-aplicación
SENDER_EMAIL=noreply@fpconnect.es

# ========== ALMACENAMIENTO (Opcional) ==========
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ========== IA/CHATBOT (Futuro) ==========
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ========== URLS FRONTEND ==========
FRONTEND_URL=http://localhost:5173
